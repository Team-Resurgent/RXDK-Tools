<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="RXDKNeighborhood.PropertiesWindow"
        Width="520"
        Height="560"
        MinWidth="420"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="*,Auto">
    <TabControl x:Name="PropertyTabs" Grid.Row="0" Margin="8" VerticalAlignment="Stretch" />
    <Border Grid.Row="1" Padding="10,6" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,1,0,0">
      <DockPanel>
        <Button DockPanel.Dock="Right" Content="Close" Click="OnCloseClick" MinWidth="80" />
        <TextBlock x:Name="StatusText" VerticalAlignment="Center" Opacity="0.85" />
      </DockPanel>
    </Border>
  </Grid>
</Window>
