<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="..\SingleFilePublish.props" />

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Rxdk.XbWatson</RootNamespace>
    <AssemblyName>xbwatson</AssemblyName>
    <ApplicationIcon Condition="$([MSBuild]::IsOSPlatform('Windows'))">..\..\src\xbWatson\Icons\xbWatson.ico</ApplicationIcon>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>

  <PropertyGroup Condition="'$(RuntimeIdentifier)' != ''">
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="12.0.4" />
    <PackageReference Include="Avalonia.Desktop" Version="12.0.4" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.4" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="12.0.4" />
    <PackageReference Include="System.Windows.Extensions" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Rxdk.XbWatson.Core\Rxdk.XbWatson.Core.csproj" />
    <ProjectReference Include="..\Rxdk.KitConfig\Rxdk.KitConfig.csproj" />
  </ItemGroup>

  <ItemGroup>
    <AvaloniaResource Include="..\..\src\xbWatson\Icons\xbWatson.ico" Link="Assets/xbWatson.ico" />
    <AvaloniaResource Include="..\..\src\xbWatson\Icons\icon1.ico" Link="Assets/redx.ico" />
    <AvaloniaResource Include="..\..\src\xbWatson\about.bmp" Link="Assets/about.bmp" />
  </ItemGroup>
</Project>
