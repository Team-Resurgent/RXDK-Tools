<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Rxdk.XbWatson.Dialogs.ExceptionDialog"
        Width="380"
        Height="200"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="An exception has occurred">
  <StackPanel Margin="16" Spacing="8">
    <TextBlock x:Name="Line1Text" />
    <TextBlock x:Name="Line2Text" />
    <TextBlock x:Name="SavedText" Text="(A crash dump has been saved)" IsVisible="False" />
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
      <Button Content="Reboot Xbox" IsDefault="True" Click="OnReboot" />
      <Button Content="Save Crash Dump" Click="OnDump" />
      <Button Content="Continue" Click="OnContinue" />
    </StackPanel>
  </StackPanel>
</Window>
